{
  "manifest_version": 3,
  "name": "ChatGPT Autofill per Rechtsklick",
  "version": "1.0.0",
  "description": "Rechtsklick auf Eingabefeld, Prompt eingeben und Antwort automatisch einfuellen.",
  "permissions": [
    "contextMenus",
    "storage",
    "activeTab"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "ChatGPT Autofill",
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_idle"
    }
  ]
}
